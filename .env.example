# Backend Environment Variables
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://admin:password@localhost:5432/monitor

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-very-long-random-secret-here-change-in-production
JWT_EXPIRES_IN=8h
REFRESH_TOKEN_SECRET=another-very-long-random-secret-change-in-production
REFRESH_TOKEN_EXPIRES_IN=7d
PRE_AUTH_TOKEN_SECRET=separate-short-lived-2fa-secret
FRONTEND_URL=http://localhost

# Admin Seeder
SEED_ADMIN_NAME=System Administrator
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-this-before-seeding
AUTO_BOOTSTRAP_DATABASE=true

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=screenshots
MINIO_USE_SSL=false

# Agent
SCREENSHOT_INTERVAL_SECONDS=30
ACTIVITY_INTERVAL_SECONDS=10
