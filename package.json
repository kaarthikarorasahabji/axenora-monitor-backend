{
  "name": "employee-monitor-backend",
  "version": "1.0.0",
  "description": "Backend server for employee monitoring system",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo",
    "seed": "npx sequelize-cli db:seed:all",
    "test": "node tests/integration.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "sequelize": "^6.33.0",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^3.0.2",
    "multer": "^2.0.2",
    "dotenv": "^16.3.1",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "otplib": "^12.0.1",
    "express-rate-limit": "^7.0.0",
    "qrcode": "^1.5.4",
    "redis": "^4.6.8",
    "minio": "^7.1.3",
    "cors": "^2.8.5",
    "uuid": "^9.0.0",
    "express-validator": "^7.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "sequelize-cli": "^6.6.1"
  }
}
