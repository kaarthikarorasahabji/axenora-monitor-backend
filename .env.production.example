# ─────────────────────────────────────────────────────────────
# Monitor Backend (Railway) — production env template
# Paste these into Railway → Variables for the monitor-backend service.
# ─────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3000

# Database (Railway provisions this)
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Redis (Railway provisions this — used for Socket.IO adapter + rate limit)
REDIS_URL=${{Redis.REDIS_URL}}

# JWT — generate fresh values
JWT_SECRET=CHANGE-ME-GENERATE-NEW-SECRET-MIN-64-CHARS
REFRESH_TOKEN_SECRET=CHANGE-ME-DIFFERENT-FROM-JWT-SECRET

# CORS — both Vercel frontends + the CRM API origin
ALLOWED_ORIGINS=https://monitor.axenoraai.in,https://crm.axenoraai.in,https://axenoraai.in
FRONTEND_URL=https://monitor.axenoraai.in
CRM_ORIGIN=https://crm.axenoraai.in

# Webhook → CRM
CRM_WEBHOOK_URL=https://api.axenoraai.in/api/attendance/monitor-webhook
CRM_WEBHOOK_SECRET=CHANGE-ME-MATCH-CRM-MONITOR_WEBHOOK_SECRET-VALUE

# CRM ↔ Monitor integration auth
INTEGRATION_API_KEY=CHANGE-ME-SAME-AS-CRM-MONITOR_INTEGRATION_API_KEY
EMBED_LOGIN_SECRET=CHANGE-ME-SAME-AS-CRM-MONITOR_EMBED_SECRET

# Storage — MinIO (skip on free trial; use Railway Volume for /uploads instead)
# MINIO_ENDPOINT=
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_BUCKET=workmonitor

# Admin seeder (first-boot only — change on first login)
ADMIN_EMAIL=admin@axenoraai.in
ADMIN_PASSWORD=CHANGE-ME-FIRST-LOGIN

# Misc
LOG_LEVEL=info
